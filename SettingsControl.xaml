<UserControl x:Class="OpenRgbSimhubBridge.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignWidth="640">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="14" MaxWidth="680" HorizontalAlignment="Left">

            <!-- ===================== Connection ===================== -->
            <TextBlock Text="Connection" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="90"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Host" VerticalAlignment="Center"/>
                <TextBox   Grid.Column="1" x:Name="HostBox" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="Port" VerticalAlignment="Center" Margin="12,0,0,0"/>
                <TextBox   Grid.Column="3" x:Name="PortBox" VerticalAlignment="Center"/>
            </Grid>

            <TextBlock Text="Devices to light" Margin="0,6,0,4" FontWeight="Bold"/>
            <TextBlock Text="Tick the OpenRGB devices the flag colour should mirror onto. Click Refresh while OpenRGB's SDK server is running to detect them."
                       TextWrapping="Wrap" Opacity="0.8" Margin="0,0,0,6"/>

            <Border BorderBrush="#40808080" BorderThickness="1" Padding="8" Margin="0,0,0,6">
                <StackPanel x:Name="DevicesPanel"/>
            </Border>

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox  Grid.Column="0" x:Name="AddDeviceBox" VerticalAlignment="Center"
                          ToolTip="Type a device name (or part of one) to match manually, then Add."/>
                <Button   Grid.Column="1" x:Name="AddDeviceButton" Content="Add by name" Margin="6,0,0,0" Padding="10,2"/>
                <Button   Grid.Column="2" x:Name="RefreshButton" Content="Refresh" Margin="6,0,0,0" Padding="10,2"/>
            </Grid>

            <TextBlock x:Name="StatusText" Text="" TextWrapping="Wrap" Opacity="0.85" Margin="0,2,0,0"/>

            <!-- ===================== Global ===================== -->
            <TextBlock Text="Global" FontSize="16" FontWeight="Bold" Margin="0,18,0,8"/>

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Brightness" VerticalAlignment="Center"/>
                <Slider    Grid.Column="1" x:Name="BrightnessSlider" Minimum="0" Maximum="1"
                           VerticalAlignment="Center" IsSnapToTickEnabled="False"/>
                <TextBlock Grid.Column="2" x:Name="BrightnessLabel" VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </Grid>

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Flash speed" VerticalAlignment="Center"/>
                <Slider    Grid.Column="1" x:Name="FlashSlider" Minimum="0" Maximum="10"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" x:Name="FlashLabel" VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </Grid>

            <CheckBox x:Name="OnlyWhenGameRunningCheck" Margin="0,4,0,8"
                      Content="Only drive devices while a game is running"/>

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Idle colour" VerticalAlignment="Center"/>
                <TextBox   Grid.Column="1" x:Name="IdleColorBox" VerticalAlignment="Center"/>
                <Border    Grid.Column="2" x:Name="IdleSwatch" Width="26" Height="20" Margin="8,0,0,0"
                           BorderBrush="#80808080" BorderThickness="1"/>
                <CheckBox  Grid.Column="3" x:Name="IdleOffCheck" Margin="12,0,0,0" VerticalAlignment="Center"
                           Content="Off when no flag"/>
            </Grid>

            <!-- ===================== Flags ===================== -->
            <TextBlock Text="Flags" FontSize="16" FontWeight="Bold" Margin="0,18,0,4"/>
            <TextBlock Text="Highest-priority active flag wins: Checkered → Black → Orange → Yellow → Blue → White → Green."
                       TextWrapping="Wrap" Opacity="0.8" Margin="0,0,0,8"/>

            <StackPanel x:Name="FlagsPanel"/>

            <!-- ===================== Footer ===================== -->
            <Button x:Name="ResetButton" Content="Reset to defaults" HorizontalAlignment="Left"
                    Padding="10,3" Margin="0,18,0,0"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
